## Integration Test Environment (sample)
# Copy to integ_tests/.env and fill in values

# Auth
TEST_USER_TOKEN=
TEST_USER_ID=
FOLIO_API_KEY=

# Convex
CONVEX_URL=
CONVEX_HTTP_CLIENT_API_KEY=

# API
API_BASE_URL=http://localhost:8000

# Prefect (required for workflow_async_e2e.test.ts)
PREFECT_API_URL=
PREFECT_API_KEY=

# Optional workflow wait tuning (milliseconds)
# WORKFLOW_E2E_TIMEOUT_MS=900000
# WORKFLOW_E2E_POLL_MS=5000
