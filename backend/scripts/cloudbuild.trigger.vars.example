# Cloud Build trigger substitutions for backend/cloudbuild.yaml
# Format: _KEY=value

# Cloud Build trigger config (trigger creation settings)
TRIGGER_NAME=backend-folio
REPO_NAME=folio
TRIGGER_REGION=global
BUILD_CONFIG=backend/cloudbuild.yaml
PUSH_BRANCH_REGEX=^dev$
TRIGGER_INCLUDED_FILES=backend/**
TRIGGER_IGNORED_FILES=frontend/**

# Advanced deploy knobs (do not change unless you know what you're doing)
_AR_HOSTNAME=us-central1-docker.pkg.dev
_DEPLOY_REGION=us-central1
_PLATFORM=managed
_ALLOW_UNAUTHENTICATED=true

# Core deploy settings
_ENV=dev
_REDIS_URL=redis://localhost:6379/0
_API_PORT=8888
_RESULT_LIMIT=3
_SERVICE_NAME=dev-folio-backend-v2

# Auto-populated by deploy script
# _API_BASE_URL=...

# Frontend-driven integrations
_CLERK_SECRET_KEY=replace_me
_CONVEX_HTTP_CLIENT_API_KEY=replace_me

# Storage
_BUCKET_NAME=replace_me
_GOOGLE_ACCESS_KEY_ID=replace_me
_GOOGLE_ACCESS_KEY_SECRET=replace_me
# Base64-encoded service account JSON (single line)
_GOOGLE_SERVICE_ACCOUNT_JSON=replace_me

# Third-party vendor integrations
_FAL_KEY=replace_me
_FOLIO_API_KEY=replace_me
_METRONOME_API_TOKEN=replace_me
_MODAL_TOKEN_ID=replace_me
_MODAL_TOKEN_SECRET=replace_me
_PREFECT_API_KEY=replace_me
_PREFECT_API_URL=replace_me
_PREFECT_DEPLOYMENT_ID=replace_me

# Feature flags
_ENABLE_BILLING_CHECKS=true
