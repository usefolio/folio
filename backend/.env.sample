# Authentication
CLERK_SECRET_KEY=your_clerk_secret_key_here
FOLIO_API_KEY=your_system_level_api_key_here

# Modal (for serverless functions)
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here

# Convex (server-side API key used by background callbacks)
CONVEX_HTTP_CLIENT_API_KEY=your_convex_api_key_here

# Redis (for background tasks)
REDIS_URL=redis://127.0.0.1:6379/0

# Server configuration
PORT=8000
API_BASE_URL=http://localhost:8000

# Google Cloud Storage
TEST_FOLIO_SHEET_CONFIG={"type": "service_account", "project_id": "your-project", "private_key_id": "your-key-id", "private_key": "<redacted>", "client_email": "your-service-account@your-project.iam.gserviceaccount.com", "client_id": "your-client-id", "auth_uri": "https://accounts.google.com/o/oauth2/auth", "token_uri": "https://oauth2.googleapis.com/token", "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs", "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com", "universe_domain": "googleapis.com"}
BUCKET_NAME=your_bucket_name

# Flower (Celery monitoring)
FLOWER_UNAUTHENTICATED_API=true

# Python paths
PYTHONPATH="${PYTHONPATH}:../libs:../queue_processor"
LIBS_PATH=./libs

# Processing limits
RESULT_LIMIT=1000

# External services
METRONOME_API_TOKEN=your_metronome_token
ENV=dev
FAL_KEY=your_fal_api_key
ENABLE_BILLING_CHECKS=false

# Prefect (workflow orchestration)
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/your-account-id/workspaces/your-workspace-id
PREFECT_API_KEY=your_prefect_api_key
PREFECT_DEPLOYMENT_ID=your_prefect_deployment_id
